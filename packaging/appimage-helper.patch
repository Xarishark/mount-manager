+def appimage_helper_path(env: dict[str, str] | None = None, source_path: Path | None = None) -> str | None:
+    """Return the original AppImage path when running from an AppImage mount."""
+    if env is None:
+        env = os.environ
+    if source_path is None:
+        source_path = Path(__file__).resolve()
+
+    appimage = env.get("APPIMAGE", "").strip()
+    appdir = env.get("APPDIR", "").strip()
+    if not appimage or not appdir:
+        return None
+
+    try:
+        source_path.relative_to(Path(appdir).resolve())
+    except ValueError:
+        return None
+
+    return appimage
+
+
+def privileged_helper_command(pkexec: str, action: str) -> list[str]:
+    appimage = appimage_helper_path()
+    if appimage is not None:
+        return [
+            pkexec,
+            appimage,
+            "--helper",
+            action,
+        ]
+
+    return [
+        pkexec,
+        sys.executable,
+        str(Path(__file__).resolve()),
+        "--helper",
+        action,
+    ]
+
+
